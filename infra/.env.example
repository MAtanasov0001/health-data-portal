# ПРИМЕРЕН файл — копирайте като .env и попълнете за ЛОКАЛНА употреба.
# .env НЕ се комитва (виж .gitignore). Тук има само ЗАМЕСТИТЕЛИ, не реални тайни.
# Реалните тайни в продукция идват от хранилище за тайни (режим C), не от файл.

DB_USER=ckan
DB_PASSWORD=changeme-local-only
DB_NAME=ckan

CKAN_SITE_URL=http://localhost:5000
API_BASE_URL=http://localhost:8000

# CKAN каталог (вариант А). Само локални заместители — реалните тайни идват от
# хранилище за тайни (режим C), никога от файл.
CKAN_SYSADMIN_NAME=ckan_admin
CKAN_SYSADMIN_PASSWORD=change-me-local-only
CKAN_SYSADMIN_EMAIL=admin@localhost
CKAN_DCAT_PROFILE=euro_dcat_ap_2
CKAN_ORG=midt
